# Local tooling / scratch — never the source of truth
.mcp.json
.claude/
node_modules/
*.skill
dist/
.DS_Store

# Reference material must NEVER be committed (brand-scrub gate) — never name a real brand here.
# Brand references live in /tmp during a build; the tool repo ships no PDFs, so ignore ALL PDFs as a guardrail
# (token-named patterns would let a brand-named file slip; the real enforcement is the 0-brand-name pre-commit grep).
**/*.pdf

# Build provenance (gitignored — not shipped)
dev/

# Python bytecode
__pycache__/
*.pyc

# fixture self-test RUN artifacts (machine-specific: reports embed the absolute linted-root path).
# Fixture audit INPUTS (redteam battery, agent-gates evidence) ARE committed — only run outputs are ignored.
skills/brand-canon-builder/assets/templates/tools/fixtures/**/audit/lint/
skills/brand-canon-builder/assets/templates/tools/fixtures/**/audit/gates/

# scheme-derive fixture run artifacts
skills/brand-canon-builder/assets/templates/tools/fixtures/scheme-derive/**/tokens/schemes/

# tokens-project fixture run artifacts (expected/ is the frozen truth)
skills/brand-canon-builder/assets/templates/tools/fixtures/tokens-project/**/tokens/web/
skills/brand-canon-builder/assets/templates/tools/fixtures/tokens-project/**/sources/
